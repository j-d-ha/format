{
  "$schema": "./format.schema.json",
  "version": 1,
  "matchPolicy": "first",
  "exclude": [
    ".git/**",
    "node_modules/**",
    "dist/**",
    "build/**",
    "bin/**",
    "obj/**"
  ],
  "formatters": [
    {
      "name": "prettier",
      "patterns": [
        "**/*.js",
        "**/*.ts",
        "**/*.jsx",
        "**/*.tsx",
        "**/*.json",
        "**/*.md",
        "**/*.yaml",
        "**/*.yml"
      ],
      "exclude": [
        "package-lock.json",
        "pnpm-lock.yaml"
      ],
      "command": [
        "bunx",
        "prettier",
        "--write",
        "$FILES"
      ]
    },
    {
      "name": "gofumpt",
      "patterns": [
        "**/*.go"
      ],
      "command": [
        "gofumpt",
        "-w",
        "$FILES"
      ]
    },
    {
      "name": "dotnet-format",
      "patterns": [
        "**/*.cs"
      ],
      "exclude": [
        "**/*.g.cs",
        "**/Generated/**/*.cs"
      ],
      "command": [
        "dotnet",
        "format",
        "--include",
        "$FILES"
      ]
    },
    {
      "name": "rustfmt",
      "patterns": [
        "**/*.rs"
      ],
      "command": [
        "rustfmt",
        "$FILES"
      ]
    },
    {
      "name": "clang-format",
      "patterns": [
        "**/*.c",
        "**/*.h",
        "**/*.cpp",
        "**/*.hpp"
      ],
      "command": [
        "clang-format",
        "-i",
        "$FILES"
      ]
    }
  ]
}
